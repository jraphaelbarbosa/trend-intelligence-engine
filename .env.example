# .env.example
# Copie este arquivo para .env na raiz do projeto e preencha suas credenciais reais.
# NUNCA comite o arquivo .env real para o GitHub.

# 🎥 YouTube API v3 (Google Cloud Console)
YOUTUBE_API_KEY="seu_youtube_api_key_aqui"

# 🗄️ Supabase PostgreSQL Connection String
# Certifique-se de que a URL de conexão use a porta 5432 direta ou direct pooler do Supabase.
DATABASE_URL="postgresql://postgres:[SENHA_DO_BANCO]@db.nfjpvmpoxwolpiyqejph.supabase.co:5432/postgres"

# 📊 Monday.com Credentials
# Token de desenvolvedor obtido na seção Perfil > Desenvolvedores da Monday.com
MONDAY_API_TOKEN="seu_monday_api_token_aqui"
MONDAY_BOARD_ID="seu_monday_board_id_aqui"

# 🧠 Gemini AI Credentials
GEMINI_API_KEY="seu_gemini_api_key_aqui"

# 🔗 n8n Master Engine Integration (Local API Key & Base URL)
# Útil para o switch_n8n_environment.py atualizar nós remotamente ou via API local.
N8N_API_KEY="sua_n8n_api_key_aqui"
N8N_BASE_URL="http://localhost:5678/api/v1"
